<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Unify" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Unify" parent="Theme.Material3.Light.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/unify_blue</item>
        <item name="colorOnPrimary">@color/unify_text_on_dark</item>

        <item name="colorSecondary">@color/unify_gold</item>
        <item name="colorOnSecondary">@color/unify_text_primary</item>

        <!-- Background / surface -->
        <item name="android:colorBackground">@color/unify_background</item>
        <item name="colorSurface">@color/unify_surface</item>
        <item name="colorOnSurface">@color/unify_text_primary</item>

        <!-- Status / navigation bars -->
        <item name="android:statusBarColor">@color/unify_blue_dark</item>
        <item name="android:navigationBarColor">@color/unify_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Optional polish -->
        <item name="android:windowBackground">@color/unify_background</item>
    </style>

    <style name="Theme.Unify.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/unify_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/unify_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Unify</item>
    </style>
</resources>