<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/unify_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dashboard_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <FrameLayout
                android:layout_width="118dp"
                android:layout_height="118dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imageInstructorProfile"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/baseline_person_24"
                    android:background="@android:color/transparent"
                    android:padding="0dp"

                    app:cornerFamily="rounded"
                    app:cornerSize="50%"

                    app:strokeColor="@color/unify_blue"
                    app:strokeWidth="3dp" />


                <TextView
                    android:id="@+id/buttonInstructorChangePhoto"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="bottom|end"
                    android:background="@color/unify_primary"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <TextView
                android:id="@+id/textInstructorProfileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="-"
                android:textColor="@color/unify_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textInstructorProfileEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="-"
                android:textColor="@color/unify_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textInstructorProfileRoleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_course_chip"
                android:paddingStart="14dp"
                android:paddingTop="6dp"
                android:paddingEnd="14dp"
                android:paddingBottom="6dp"
                android:text="INSTRUCTOR"
                android:textColor="@color/unify_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBarInstructorProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/profile_details"
            android:textColor="@color/unify_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textInstructorProfileFaculty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dashboard_card"
            android:padding="18dp"
            android:text="-"
            android:textColor="@color/unify_text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textInstructorProfileRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dashboard_card"
            android:padding="18dp"
            android:text="INSTRUCTOR"
            android:textColor="@color/unify_text_primary"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonInstructorOpenCalendar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="28dp"
            android:text="Teaching Calendar"
            android:textAllCaps="false"
            android:textColor="@color/unify_blue"
            android:textStyle="bold"
            app:backgroundTint="@color/unify_surface"
            app:cornerRadius="@dimen/radius_lg"
            app:strokeColor="@color/unify_blue"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/buttonInstructorLogout"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="28dp"
            android:text="@string/logout" />

    </LinearLayout>
</ScrollView>