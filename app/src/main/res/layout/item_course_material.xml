<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_dashboard_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textMaterialType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/unify_primary"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="@string/note"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textMaterialTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/material_title"
        android:textColor="@color/unify_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textMaterialDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/material_description"
        android:textColor="@color/unify_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textMaterialDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/unify_text_secondary"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonOpenMaterial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/open" />

        <Button
            android:id="@+id/buttonDeleteMaterial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/delete" />
    </LinearLayout>

</LinearLayout>