<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootMessageItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/textMessageSender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="44dp"
        android:layout_marginBottom="3dp"
        android:text="Sender"
        android:textColor="@color/unify_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layoutMessageRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageMessageAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@color/unify_background"
            android:contentDescription="@string/avatar"
            android:scaleType="centerCrop"
            android:src="@drawable/baseline_person_24"
            android:visibility="gone"
            app:shapeAppearanceOverlay="@style/UnifyAvatarCircle"
            app:strokeColor="@color/unify_border"
            app:strokeWidth="1dp" />

        <TextView
            android:id="@+id/textMessageBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="260dp"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp"
            android:text="Message text"
            android:textColor="@color/unify_text_primary"
            android:textSize="15sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/textMessageTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="44dp"
        android:layout_marginTop="2dp"
        android:text="11:20"
        android:textColor="@color/unify_text_secondary"
        android:textSize="10sp" />

</LinearLayout>