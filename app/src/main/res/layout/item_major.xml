<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/announcement_card_stroke">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/textMajorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/textMajorCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/unify_primary"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/textMajorFaculty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/unify_text_secondary"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/textMajorId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/unify_text_secondary"
            android:paddingBottom="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDeleteMajor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/delete" />



    </LinearLayout>

</com.google.android.material.card.MaterialCardView>