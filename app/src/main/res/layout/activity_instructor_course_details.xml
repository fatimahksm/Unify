<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/unify_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textCourseDetailsTitle"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/unify_text_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/textCourseDetailsCode"
            android:layout_marginTop="6dp"
            android:textColor="@color/unify_primary"
            android:textSize="14sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- ACTION CARDS -->

        <LinearLayout
            android:layout_marginTop="30dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="@string/manage_students"
                android:id="@+id/cardManageStudents"
                android:background="@drawable/bg_dashboard_card"
                android:padding="20dp"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:textAlignment="center" />

            <TextView
                android:text="@string/announcements"
                android:background="@drawable/bg_dashboard_card"
                android:padding="20dp"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:textAlignment="center"
                android:id="@+id/cardAnnouncements" />

            <TextView
                android:id="@+id/cardMaterials"
                android:text="Course Materials"
                android:background="@drawable/bg_dashboard_card"
                android:padding="20dp"
                android:textSize="16sp"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/cardCourseChat"
                android:text="@string/course_chat"
                android:background="@drawable/bg_dashboard_card"
                android:padding="20dp"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:textAlignment="center" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>