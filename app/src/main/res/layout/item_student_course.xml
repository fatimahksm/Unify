<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_md"
    android:layout_marginEnd="@dimen/space_md"
    android:layout_marginBottom="@dimen/space_md"
    app:cardBackgroundColor="@color/unify_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/unify_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="118dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <FrameLayout
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_course_thumb">

            <TextView
                android:id="@+id/textCourseInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="C"
                android:textColor="@color/white"
                android:textSize="23sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textCourseTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="3"
                android:text="SPRING2026-Tyre-GID215-Drawing II"
                android:textColor="@color/unify_text_primary"
                android:textSize="18sp" />

            <!-- Row of chips: semester chip + status badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textCourseMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_course_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="SPRING2026"
                    android:textColor="@color/unify_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="IN PROGRESS"
                    xmlns:tools="http://schemas.android.com/tools" />

            </LinearLayout>

            <!-- Final grade — only visible when course completed and result published -->
            <TextView
                android:id="@+id/textGrade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/unify_blue"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Grade: A"
                xmlns:tools="http://schemas.android.com/tools" />

            <TextView
                android:id="@+id/textCourseCode"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textCourseInstructor"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:gravity="top|center_horizontal"
            android:text="⋮"
            android:textColor="@color/unify_text_primary"
            android:textSize="30sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>