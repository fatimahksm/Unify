<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootStudentSocial"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/unify_background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/layoutSocialHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/unify_surface"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/textSocialTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/social"
            android:textColor="@color/unify_text_primary"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSocialSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="@string/social_hint"
            android:textColor="@color/unify_text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/layoutAddPostCard"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_dashboard_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <TextView
                android:id="@+id/textSocialAvatar"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_course_badge"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/unify_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textAddPostHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/create_post_hint"
                android:textColor="@color/unify_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textAddPostButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_course_chip"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/add_post"
                android:textColor="@color/unify_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressSocial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="18dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layoutSocialEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="26dp"
        android:visibility="gone">

        <TextView
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_course_badge"
            android:gravity="center"
            android:text="💬"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/textSocialEmptyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="@string/no_posts_found"
            android:textColor="@color/unify_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSocialEmptySubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:text="@string/social_empty_hint"
            android:textColor="@color/unify_text_secondary"
            android:textSize="13sp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSocialPosts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp" />

</LinearLayout>