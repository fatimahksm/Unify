<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginEnd="16dp"
    android:background="@drawable/bg_dashboard_card"
    android:elevation="2dp"
    android:orientation="horizontal"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="82dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textCalendarTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="08:00 - 10:00"
            android:textColor="@color/unify_blue"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="14dp"
        android:background="@color/unify_border" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textCalendarCourseTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mobile Development"
            android:textColor="@color/unify_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textCalendarCourseCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_course_code_badge"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:text="MOB301"
            android:textColor="@color/unify_blue"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textCalendarDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="Section A • Instructor: Dr. Ahmad"
            android:textColor="@color/unify_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textCalendarRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Room A1"
            android:textColor="@color/unify_text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>