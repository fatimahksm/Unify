<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootStudentMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/unify_background">

    <FrameLayout
        android:id="@+id/studentFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/layoutStudentBottomNav"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:orientation="horizontal"
        android:background="@color/unify_surface"
        android:elevation="10dp">

        <LinearLayout
            android:id="@+id/navCourses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/indicatorCourses"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@color/unify_gold" />

            <ImageView
                android:id="@+id/iconCourses"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="9dp"
                android:src="@drawable/baseline_library_books_24"
                android:tint="@color/unify_blue" />

            <TextView
                android:id="@+id/textCourses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/courses"
                android:textColor="@color/unify_blue"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSocial"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/indicatorSocial"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@android:color/transparent" />

            <ImageView
                android:id="@+id/iconSocial"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="9dp"
                android:src="@drawable/baseline_groups_24"
                android:tint="@color/unify_text_secondary" />

            <TextView
                android:id="@+id/textSocial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/social"
                android:textColor="@color/unify_text_secondary"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAnnouncements"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/indicatorAnnouncements"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@android:color/transparent" />

            <ImageView
                android:id="@+id/iconAnnouncements"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="9dp"
                android:src="@drawable/baseline_info_24"
                android:tint="@color/unify_text_secondary" />

            <TextView
                android:id="@+id/textAnnouncements"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/announcements"
                android:textColor="@color/unify_text_secondary"
                android:textSize="8sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navChats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/indicatorChats"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@android:color/transparent" />

            <ImageView
                android:id="@+id/iconChats"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="9dp"
                android:src="@drawable/baseline_chat_24"
                android:tint="@color/unify_text_secondary" />

            <TextView
                android:id="@+id/textChats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/chats"
                android:textColor="@color/unify_text_secondary"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navNotifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/indicatorNotifications"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@android:color/transparent" />

            <ImageView
                android:id="@+id/iconNotifications"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="9dp"
                android:src="@drawable/baseline_notifications_24"
                android:tint="@color/unify_text_secondary" />

            <TextView
                android:id="@+id/textNotifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/notifications"
                android:textColor="@color/unify_text_secondary"
                android:textSize="8sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/indicatorProfile"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@android:color/transparent" />

            <ImageView
                android:id="@+id/iconProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="9dp"
                android:src="@drawable/baseline_person_24"
                android:tint="@color/unify_text_secondary" />

            <TextView
                android:id="@+id/textProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/profile"
                android:textColor="@color/unify_text_secondary"
                android:textSize="9sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>