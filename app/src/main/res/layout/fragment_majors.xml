<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/majors"
            android:textSize="30sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/majors_subtitle"
            android:textSize="15sp"
            android:paddingBottom="16dp" />

        <ProgressBar
            android:id="@+id/progressBarMajors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/textEmptyMajors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_majors_found"
            android:textSize="16sp"
            android:gravity="center"
            android:visibility="gone"
            android:paddingTop="32dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMajors"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="90dp" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddMajor"
        android:contentDescription="@string/add_major"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="100dp"

        app:backgroundTint="@color/unify_primary"
        app:tint="@color/unify_text_on_dark"
        app:srcCompat="@android:drawable/ic_input_add"
        />

</FrameLayout>